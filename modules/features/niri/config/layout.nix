{
  layout = {
    always-center-single-column = true;
    gaps = 12;
    center-focused-column = "never";

    preset-column-widths = [
      { proportion = 0.4; }
      { proportion = 0.6; }
      { proportion = 0.7; }
    ];

    default-column-width.proportion = 0.4;

    focus-ring = {
      width = 4;
      active.color = "#74c7ec";
      inactive.color = "#45475a";
    };

    border.enable = false;
  };
}
