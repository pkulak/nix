{
  input = {
    keyboard = {
      numlock = true;
      repeat-delay = 200;
      repeat-rate = 30;
    };

    touchpad = {
      tap = true;
      natural-scroll = true;
    };

    mouse.natural-scroll = true;

    trackball = {
      natural-scroll = true;
      scroll-method = "on-button-down";
      scroll-button = 275;
    };

    focus-follows-mouse = {
      enable = true;
      max-scroll-amount = "0%";
    };
  };
}
